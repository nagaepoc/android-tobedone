<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base Android theme. All visual theming is handled by Compose's Material 3
        (see ToBeDoneTheme in MainActivity.kt). We only need a lightweight shell
        here so the Activity can launch without a crash.
    -->
    <style name="Theme.ToBeDone" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
